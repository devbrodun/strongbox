#!/usr/bin/env bash
# bin/strongbox — StrongBox secrets manager entrypoint
#
# Responsibilities owned by Person 1:
#   - Boot in SEALED state
#   - POST /v1/sys/init     (one-time init: generate KEK, split via Shamir)
#   - POST /v1/sys/unseal   (collect shares, reconstruct KEK, transition to UNSEALED)
#   - POST /v1/sys/seal     (zero KEK, return to SEALED)
#   - GET  /v1/sys/health
#   - PUT  /v1/secrets/{path}           (encrypt + store)
#   - GET  /v1/secrets/{path}[?version] (decrypt + return)
#   - DELETE /v1/secrets/{path}
#
# Other routes (auth, leases, dynamic, audit, cluster) are handled by their
# respective lib/*.sh modules sourced here. HTTP dispatch lives in lib/http.sh.
#
# Config (from config.yaml or env overrides):
#   STRONGBOX_NODE_ID      (required)
#   STRONGBOX_BIND_ADDR    (default: 0.0.0.0)
#   STRONGBOX_PORT         (default: 8200)
#   STRONGBOX_SHAMIR_K     (default: 3)
#   STRONGBOX_SHAMIR_N     (default: 5)
#   STRONGBOX_DATA_DIR     (default: /var/lib/strongbox)
#   STRONGBOX_AUDIT_LOG    (default: /var/lib/strongbox/audit.log)
#   STRONGBOX_LEASE_TTL    (default: 3600)
#   STRONGBOX_LEASE_MAX    (default: 86400)

set -euo pipefail
