# ---------------------------------------------------------------------------
# Main: start HTTP server
# ---------------------------------------------------------------------------
main() {
    mkdir -p "$STRONGBOX_DATA_DIR"

    if _is_initialized; then
        STRONGBOX_INIT="true"
        echo "[strongbox] node=$STRONGBOX_NODE_ID port=$STRONGBOX_PORT state=SEALED (initialized, awaiting unseal)" >&2
    else
        echo "[strongbox] node=$STRONGBOX_NODE_ID port=$STRONGBOX_PORT state=SEALED (not initialized)" >&2
    fi

    # Start background processes
    lease_reaper_start
    consensus_start

    # Start HTTP server (blocks)
    http_serve "$STRONGBOX_BIND_ADDR" "$STRONGBOX_PORT"
}

main "$@"
