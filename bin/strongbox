# ---------------------------------------------------------------------------
handle_sys_seal() {
    local token="${1:-}"
    if ! auth_validate_token "$token" "sys" "write"; then
        http_respond 403 '{"error":"forbidden"}'
        return
    fi

    crypto_unload_kek
    STRONGBOX_SEALED="true"
