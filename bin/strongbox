# ---------------------------------------------------------------------------
# Route: GET /v1/sys/health
# Always responds, even when sealed.
# ---------------------------------------------------------------------------
handle_sys_health() {
    local leader term node_id
    leader=$(consensus_is_leader && echo "true" || echo "false")
    term=$(consensus_current_term)
    node_id="$STRONGBOX_NODE_ID"

    http_respond 200 "{\"sealed\":${STRONGBOX_SEALED},\"leader\":${leader},\"term\":${term},\"node_id\":\"${node_id}\"}"
}

# ---------------------------------------------------------------------------
# Route: PUT /v1/secrets/{path}   body: {"data":{...}}
# Encrypt the data value and store it with versioning.
# ---------------------------------------------------------------------------
handle_secret_write() {
    local path="${1:?}" token="${2:-}" body="${3:-}"

    _assert_unsealed || return

    if ! auth_validate_token "$token" "$path" "write"; then
        http_respond 403 '{"error":"forbidden"}'
        return
    fi

    # Forward to leader if we're a follower
    if ! consensus_is_leader; then
        local leader_addr
        leader_addr=$(consensus_leader_addr)
        http_respond 307 "{\"error\":\"not leader\",\"leader\":\"${leader_addr}\"}"
        return
    fi

    # Extract data as JSON string to encrypt
    local data_json
    data_json=$(echo "$body" | python3 -c "
import sys,json
d=json.load(sys.stdin)
print(json.dumps(d.get('data',{})))
" 2>/dev/null) || { http_respond 400 '{"error":"invalid JSON"}'; return; }

    # Encrypt
    local blob
    blob=$(crypto_encrypt_secret "$data_json") || {
        http_respond 500 '{"error":"encryption failed"}'
        return
    }

    # Store with versioning
    local version
    version=$(storage_put "secret/${path}" "$blob")

    audit_append "secret" "$token" "write" "secret/${path}" "v${version}"
    http_respond 201 "{\"version\":${version}}"
}

# ---------------------------------------------------------------------------
# Route: GET /v1/secrets/{path}[?version=N]
# Decrypt and return secret data, issue a lease.
# ---------------------------------------------------------------------------
handle_secret_read() {
    local path="${1:?}" token="${2:-}" version="${3:-}"

    _assert_unsealed || return

    if ! auth_validate_token "$token" "$path" "read"; then
        http_respond 403 '{"error":"forbidden"}'
        return
    fi

    local blob
    blob=$(storage_get "secret/${path}" "$version") || {
        http_respond 404 '{"error":"not found"}'
        return
    }

    local plaintext
    plaintext=$(crypto_decrypt_secret "$blob") || {
        http_respond 500 '{"error":"decryption failed"}'
        return
    }

    local actual_version
    if [[ -n "$version" ]]; then
        actual_version="$version"
    else
        actual_version=$(storage_latest_version "secret/${path}")
    fi

    # Issue a lease
    local lease_json
    lease_json=$(lease_create "secret/${path}" "$STRONGBOX_LEASE_TTL" "$STRONGBOX_LEASE_MAX")

    audit_append "secret" "$token" "read" "secret/${path}" "v${actual_version}"

    # plaintext is already a JSON object (the data field)
    http_respond 200 "{\"data\":${plaintext},\"version\":${actual_version},\"lease\":${lease_json}}"
}

# ---------------------------------------------------------------------------
# Route: DELETE /v1/secrets/{path}
# ---------------------------------------------------------------------------
handle_secret_delete() {
    local path="${1:?}" token="${2:-}"

    _assert_unsealed || return

    if ! auth_validate_token "$token" "$path" "delete"; then
        http_respond 403 '{"error":"forbidden"}'
        return
    fi

    if ! consensus_is_leader; then
        local leader_addr
        leader_addr=$(consensus_leader_addr)
        http_respond 307 "{\"error\":\"not leader\",\"leader\":\"${leader_addr}\"}"
        return
    fi

    storage_delete "secret/${path}" || {
        http_respond 404 '{"error":"not found"}'
        return
    }

    audit_append "secret" "$token" "delete" "secret/${path}" "success"
    http_respond 204 ""
}
