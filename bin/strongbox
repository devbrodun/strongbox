# Zero all share buffers from the unseal array and reset progress.
_unseal_zero_shares() {
    local i
    for (( i=0; i < ${#_UNSEAL_SHARES[@]:-0}; i++ )); do
        local s="${_UNSEAL_SHARES[$i]}"
        _UNSEAL_SHARES[$i]="$(printf '%0.s0' $(seq 1 ${#s}))"
    done
    _UNSEAL_SHARES=()
    _UNSEAL_PROGRESS=0
}

